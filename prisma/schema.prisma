generator client {
  provider = "prisma-client"
  output   = "../app/server/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    Int              @id @default(autoincrement())
  email                 String           @unique
  name                  String?
  picture               String?
  displayName           String?
  activityLabel         String?
  atecoCode             String?
  atecoLabel            String?
  taxYear               Int?
  startupRate           Float            @default(0.15)
  onboardingCompletedAt DateTime?
  planTier              String           @default("FREE")
  subscriptionStatus    String           @default("INACTIVE")
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  settings              Settings?
  entries               Entry[]
  recurringPayments     RecurringPayment[]
  oneTimePayments       OneTimePayment[]
  calculationRuns       CalculationRun[]
  auditEvents           AuditEvent[]
}

model Entry {
  id          Int       @id @default(autoincrement())
  userId      Int?      
  date        DateTime
  type        EntryType
  hours       Float?
  amount      Float?
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([userId])
}

enum EntryType {
  HOURLY
  PROJECT
}

model Settings {
  id                    Int      @id @default(autoincrement())
  userId                Int?     @unique
  hourlyRate            Float    @default(30)
  coefficiente          Float    @default(0.67)
  irpefRate             Float    @default(0.15)
  inpsType              String   @default("GESTIONE_SEPARATA")
  inpsRate              Float    @default(0.2607)
  inpsFixedAnnual       Float    @default(0)
  inpsMinimaleThreshold Float    @default(18808)
  inpsExcessRate        Float    @default(0.156)
  accountantAnnual      Float    @default(300)
  updatedAt             DateTime @updatedAt @default(now())
  user                  User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model RecurringPayment {
  id          Int       @id @default(autoincrement())
  userId      Int?
  name        String
  amount      Float
  frequency   String
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model OneTimePayment {
  id          Int       @id @default(autoincrement())
  userId      Int?
  name        String
  amount      Float
  date        DateTime
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model CalculationRun {
  id            Int      @id @default(autoincrement())
  userId        Int
  source        String
  rulesetYear   Int
  rulesetVersion String
  inputSnapshot Json
  outputSnapshot Json
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model AuditEvent {
  id         Int      @id @default(autoincrement())
  userId     Int
  action     String
  entityType String
  entityId   String?
  payload    Json?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
