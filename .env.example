DATABASE_URL="postgresql://user:password@localhost:5432/fattura_tracker"

# Dev auth bypass (set to "false" to enforce auth on localhost)
DEV_AUTH_BYPASS=true

# Auth (nuxt-auth-utils)
NUXT_SESSION_PASSWORD="generate-a-random-32-char-string-for-session-encryption"
NUXT_OAUTH_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
NUXT_OAUTH_GOOGLE_CLIENT_SECRET="your-google-client-secret"
ALLOWED_EMAIL="your-email@example.com"
