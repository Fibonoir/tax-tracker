DATABASE_URL="postgresql://user:password@localhost:5432/fattura_tracker"

# Dev auth bypass (set to "false" to enforce auth on localhost)
DEV_AUTH_BYPASS=true

# Auth (Better Auth)
BETTER_AUTH_SECRET="generate-a-random-32-char-string-for-session-encryption"
# BETTER_AUTH_URL must match the app's actual public origin.
# Local: http://localhost:3000  |  Production: https://chiaromvp.vercel.app (NOT a subdomain like auth.chiaro.app)
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth — In Google Cloud Console → Credentials → OAuth 2.0 Client,
# optional if you only want email/password auth
# add these as Authorized redirect URIs (NOT "Authorized JavaScript origins"):
#   Local:      http://localhost:3000/api/auth/callback/google
#   Production: https://YOUR-DOMAIN.com/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
BETA_ALLOWLIST="founder@example.com,beta-user@example.com"

# Email (Resend — https://resend.com, free tier: 100 emails/day)
# Leave RESEND_API_KEY empty in dev — emails print to console instead.
RESEND_API_KEY=""
# EMAIL_FROM requires a verified domain in Resend, or use their sandbox:
EMAIL_FROM="Chiaro <onboarding@resend.dev>"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_CORE_CLARITY_PRICE_ID=""
STRIPE_PLANNING_SCENARIOS_PRICE_ID=""
